{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A clothing item in the boutique.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the piece" },
        "category": { "type": "string", "description": "Category (e.g., dress, blouse)" },
        "price": { "type": "number", "description": "Price of the item" },
        "sku": { "type": "string", "description": "Internal SKU code" },
        "description": { "type": "string", "description": "Detailed description" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "isArchived": { "type": "boolean", "description": "Soft delete status" }
      },
      "required": ["name", "category", "price", "createdAt"]
    },
    "Variation": {
      "title": "Variation",
      "description": "A specific color and size combination for a product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "color": { "type": "string", "description": "Color variation" },
        "size": { "type": "string", "description": "Size variation (P, M, G, GG, etc.)" },
        "quantity": { "type": "number", "description": "Current stock quantity" }
      },
      "required": ["productId", "color", "size", "quantity"]
    },
    "Movement": {
      "title": "Movement",
      "description": "Stock movement record (entry or exit).",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the product" },
        "variationId": { "type": "string", "description": "Reference to the specific variation" },
        "type": { "type": "string", "enum": ["entry", "exit"], "description": "Type of movement" },
        "quantity": { "type": "number", "description": "Quantity moved" },
        "date": { "type": "string", "format": "date-time", "description": "Timestamp of movement" },
        "reason": { "type": "string", "description": "Reason for movement (e.g., sale, restock)" },
        "variationInfo": { "type": "string", "description": "Summary of color/size" }
      },
      "required": ["productId", "variationId", "type", "quantity", "date"]
    },
    "User": {
      "title": "User",
      "description": "System user with specific roles and permissions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "permissions", "isActive", "createdAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of a completed sale.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "Reference to client (optional)" },
        "clientName": { "type": "string", "description": "Name of the client" },
        "date": { "type": "string", "format": "date-time", "description": "Timestamp of sale" },
        "productId": { "type": "string", "description": "Reference to product sold" },
        "productName": { "type": "string", "description": "Name of product at time of sale" },
        "variationId": { "type": "string", "description": "Reference to variation sold" },
        "variationInfo": { "type": "string", "description": "Summary of color/size" },
        "quantity": { "type": "number", "description": "Quantity sold" },
        "unitPrice": { "type": "number", "description": "Price per unit at time of sale" },
        "totalValue": { "type": "number", "description": "Total value of the sale" },
        "observation": { "type": "string", "description": "Notes about the sale" },
        "isCancelled": { "type": "boolean", "description": "Whether the sale was cancelled" }
      },
      "required": ["clientName", "date", "productId", "productName", "quantity", "unitPrice", "totalValue"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Boutique client information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "observations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "createdAt"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "Reserve a product for a specific client.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "productId": { "type": "string" },
        "variationId": { "type": "string" },
        "quantity": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled", "expired"] }
      },
      "required": ["customerId", "customerName", "productId", "variationId", "quantity", "startDate", "endDate", "status"]
    },
    "BoutiqueSettings": {
      "title": "BoutiqueSettings",
      "description": "Global system configuration.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cnpj": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "lowStockAlert": { "type": "number" },
        "darkMode": { "type": "boolean" },
        "monthlyReportEmail": { "type": "boolean" }
      },
      "required": ["name", "lowStockAlert"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Immutable log of sensitive system actions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "action", "entityType", "entityId", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of boutique products."
    },
    "/products/{productId}/variations/{variationId}": {
      "schema": "Variation",
      "description": "Sub-collection of variations for a specific product."
    },
    "/movements/{movementId}": {
      "schema": "Movement",
      "description": "Collection of all stock movements."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of all completed sales."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and permissions."
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of boutique clients."
    },
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Collection of product reservations."
    },
    "/settings/global": {
      "schema": "BoutiqueSettings",
      "description": "Single document for global settings."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Collection of security and activity logs."
    }
  }
}
